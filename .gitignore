# Grav core (niet deployen — staat al op server via installatie)
/system/
/vendor/
/bin/
/composer.json
/composer.lock
/now.json
/assets/
/webserver-configs/
/.phan/
/.github/
*.code-workspace
.htaccess
CHANGELOG.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
LICENSE.txt
README.md
SECURITY.md

# Cache, logs, tmp
/cache/*
/logs/*
/tmp/*
/backup/*

# Uitzonderingen: mappen bewaren maar inhoud niet
!cache/.gitkeep
!logs/.gitkeep
!tmp/.gitkeep
!backup/.gitkeep

# Automatisch gegenereerde afbeeldingen
/images/

# Omgevingsvariabelen (nooit committen)
.env
.env.*

# OS bestanden
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Grav user data die niet in repo hoort
/user/data/
/user/accounts/

# Plugins: enkel onze eigen bestanden, geen vendor/updates
/user/plugins/*/vendor/
/user/plugins/*/node_modules/
/user/plugins/*/*.lock
/user/plugins/*/hebe.json
