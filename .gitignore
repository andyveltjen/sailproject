# Grav core (niet deployen — staat al op server via installatie)
/system/
/vendor/
/bin/
/composer.json
/composer.lock
/now.json

# Cache, logs, tmp
/cache/*
/logs/*
/tmp/*
/backup/*

# Uitzonderingen: mappen bewaren maar inhoud niet
!cache/.gitkeep
!logs/.gitkeep
!tmp/.gitkeep
!backup/.gitkeep

# Assets (automatisch gegenereerd)
/images/

# OS bestanden
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Grav user data die niet in repo hoort
/user/data/
/user/accounts/

# Wel deployen
!/user/
!/user/config/
!/user/pages/
!/user/plugins/
!/user/themes/
