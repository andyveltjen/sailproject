{% extends 'partials/base.html.twig' %}

{% set h = page.header %}

{% block body %}

{# ── Top navigation ── #}
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="{{ base_url_absolute }}" class="flex items-center">
            <img src="{{ url('theme://images/logo.png') }}" alt="{{ site.title }}" class="h-9 w-auto">
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm text-slate-600">
            <a href="{{ base_url_absolute }}" class="hover:text-sail-600 font-medium text-slate-900">Project</a>
            <a href="{{ base_url_absolute }}/wiki" class="hover:text-sail-600">Wiki of Research</a>
            <a href="#team" class="hover:text-sail-600">Team</a>
            <a href="#contact" class="hover:text-sail-600">Contact</a>
        </nav>
        <a href="{{ base_url_absolute }}/wiki" class="hidden md:inline-flex items-center gap-2 bg-sail-500 hover:bg-sail-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            Lees de Wiki <i class="fa fa-arrow-right text-xs"></i>
        </a>
    </div>
</header>

{# ── Hero ── #}
<section class="pt-32 pb-20 px-6 bg-gradient-to-br from-slate-50 via-sail-50 to-white">
    <div class="max-w-6xl mx-auto">
        <div class="max-w-3xl">
            <span class="inline-flex items-center gap-2 bg-sail-100 text-sail-700 text-xs font-medium px-3 py-1 rounded-full mb-6">
                <span class="w-1.5 h-1.5 rounded-full bg-sail-500"></span>
                Onderzoeksproject 2025–2028
            </span>
            <h1 class="text-5xl font-bold text-slate-900 leading-tight mb-4">
                {{ page.title }}
            </h1>
            {% if h.hero.subtitle %}
            <p class="text-2xl text-sail-600 font-medium mb-6">{{ h.hero.subtitle }}</p>
            {% endif %}
            {% if h.hero.intro %}
            <p class="text-xl text-slate-500 leading-relaxed mb-10 max-w-2xl">{{ h.hero.intro }}</p>
            {% endif %}
            <p class="text-sm text-slate-400 mb-8">
                Een initiatief van het expertisecentrum
                <a href="https://research-expertise.ucll.be/en/expertcenters/education-development"
                   target="_blank" rel="noopener noreferrer"
                   class="text-sail-500 hover:text-sail-600 underline underline-offset-2 transition-colors">Education &amp; Development</a>
                van Hogeschool UCLL
            </p>
            <div class="flex flex-wrap gap-4">
                {% if h.hero.cta_text %}
                <a href="{{ base_url_absolute }}/wiki" class="inline-flex items-center gap-2 bg-sail-500 hover:bg-sail-600 text-white font-medium px-6 py-3 rounded-xl transition-colors shadow-lg shadow-sail-200">
                    {{ h.hero.cta_text }} <i class="fa fa-arrow-right"></i>
                </a>
                {% endif %}
                {% if h.hero.second_cta_text %}
                <a href="#project" class="inline-flex items-center gap-2 text-slate-600 hover:text-slate-900 font-medium px-6 py-3 rounded-xl border border-slate-200 hover:border-slate-300 transition-colors">
                    {{ h.hero.second_cta_text }}
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# ── Project info ── #}
<section id="project" class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-3xl font-bold text-slate-900 mb-4">{{ h.project.title ?: 'Over het project' }}</h2>
                {% if h.project.description1 %}
                <p class="text-slate-500 leading-relaxed mb-4">{{ h.project.description1 }}</p>
                {% endif %}
                {% if h.project.description2 %}
                <p class="text-slate-500 leading-relaxed mb-6">{{ h.project.description2 }}</p>
                {% endif %}
                {% if h.project.checks %}
                <div class="flex flex-col gap-3">
                    {% for check in h.project.checks %}
                    <div class="flex items-start gap-3">
                        <span class="w-6 h-6 rounded-full bg-sail-100 flex items-center justify-center mt-0.5 flex-shrink-0">
                            <i class="fa fa-check text-sail-600 text-xs"></i>
                        </span>
                        <span class="text-slate-600 text-sm">{{ check.text }}</span>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% if h.project.stats %}
            <div class="grid grid-cols-2 gap-4">
                {% for stat in h.project.stats %}
                <div class="{% if loop.index is odd %}bg-slate-50{% else %}bg-sail-50{% endif %} rounded-2xl p-6">
                    <div class="text-3xl font-bold text-sail-600 mb-1">{{ stat.number }}</div>
                    <div class="text-sm text-slate-500">{{ stat.label }}</div>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>
</section>

{# ── Wiki kaarten ── #}
{% if h.wiki_sections %}
<section class="py-20 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
        <div class="mb-12">
            <h2 class="text-3xl font-bold text-slate-900 mb-3">{{ h.wiki_sections.title ?: 'Wiki of Research' }}</h2>
            <p class="text-slate-500 max-w-xl">{{ h.wiki_sections.subtitle ?: 'Al ons onderzoek, gestructureerd en doorzoekbaar.' }}</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
            {% for section in h.wiki_sections.items %}
            <a href="{{ base_url_absolute }}{{ section.url }}" class="group bg-white rounded-2xl p-6 border border-slate-200 hover:border-sail-300 hover:shadow-lg transition-all">
                <div class="w-10 h-10 rounded-xl bg-sail-100 flex items-center justify-center mb-4 group-hover:bg-sail-500 transition-colors">
                    <i class="fa {{ section.icon }} text-sail-600 group-hover:text-white transition-colors"></i>
                </div>
                <h3 class="font-semibold text-slate-900 mb-2">{{ section.title }}</h3>
                <p class="text-sm text-slate-500">{{ section.description }}</p>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── Tijdlijn ── #}
{% if h.timeline %}
<section class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-12">{{ h.timeline.title ?: 'Tijdlijn' }}</h2>

        {# Desktop: 3-kolommen grid met vaste middenkolom voor de lijn en bollen #}
        <div class="hidden md:block">
            {% for phase in h.timeline.items %}
            <div class="grid items-center" style="grid-template-columns: 1fr 2rem 1fr;">

                {# Linkerkolom #}
                {% if loop.index is odd %}
                <div class="text-right pr-6">
                    <div class="font-semibold text-slate-900">{{ phase.name }}</div>
                    <div class="text-sm text-slate-400">{{ phase.period }}</div>
                </div>
                {% else %}
                <div class="text-right pr-6">
                    <span class="inline-block text-xs px-2.5 py-1 rounded-full
                        {% if phase.done %}bg-sail-100 text-sail-700{% else %}bg-slate-100 text-slate-500{% endif %}">
                        {{ phase.status }}
                    </span>
                </div>
                {% endif %}

                {# Middenkolom: bol + lijnstukjes #}
                <div class="flex flex-col items-center">
                    {% if not loop.first %}
                    <div class="w-px h-6 bg-slate-200"></div>
                    {% endif %}
                    <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center flex-shrink-0
                        {% if phase.done %}bg-sail-500 border-sail-500{% else %}bg-white border-slate-300{% endif %}">
                        {% if phase.done %}<i class="fa fa-check text-white text-xs"></i>{% endif %}
                    </div>
                    {% if not loop.last %}
                    <div class="w-px h-6 bg-slate-200"></div>
                    {% endif %}
                </div>

                {# Rechterkolom #}
                {% if loop.index is odd %}
                <div class="pl-6">
                    <span class="inline-block text-xs px-2.5 py-1 rounded-full
                        {% if phase.done %}bg-sail-100 text-sail-700{% else %}bg-slate-100 text-slate-500{% endif %}">
                        {{ phase.status }}
                    </span>
                </div>
                {% else %}
                <div class="pl-6">
                    <div class="font-semibold text-slate-900">{{ phase.name }}</div>
                    <div class="text-sm text-slate-400">{{ phase.period }}</div>
                </div>
                {% endif %}

            </div>
            {% endfor %}
        </div>

        {# Mobiel: verticale lijst #}
        <div class="md:hidden relative">
            <div class="absolute left-4 top-0 bottom-0 w-px bg-slate-200"></div>
            {% for phase in h.timeline.items %}
            <div class="relative mb-8 pl-14">
                <div class="absolute left-0 w-8 h-8 rounded-full border-2 flex items-center justify-center
                    {% if phase.done %}bg-sail-500 border-sail-500{% else %}bg-white border-slate-300{% endif %}">
                    {% if phase.done %}<i class="fa fa-check text-white text-xs"></i>{% endif %}
                </div>
                <div class="font-semibold text-slate-900">{{ phase.name }}</div>
                <div class="text-sm text-slate-400 mb-1">{{ phase.period }}</div>
                <span class="inline-block text-xs px-2.5 py-1 rounded-full
                    {% if phase.done %}bg-sail-100 text-sail-700{% else %}bg-slate-100 text-slate-500{% endif %}">
                    {{ phase.status }}
                </span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── Team ── #}
{% if h.team %}
<section id="team" class="py-20 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-12">{{ h.team.title ?: 'Het team' }}</h2>
        <div class="grid md:grid-cols-3 gap-6">
            {% for member in h.team.items %}
            <div class="bg-white rounded-2xl p-6 border border-slate-200">
                <div class="w-12 h-12 rounded-full bg-sail-100 flex items-center justify-center mb-4">
                    <i class="fa fa-user text-sail-500"></i>
                </div>
                <div class="font-semibold text-slate-900">{{ member.name }}</div>
                <div class="text-sm text-slate-400 mt-1">{{ member.role }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── Footer ── #}
<footer id="contact" class="py-12 px-6 bg-slate-900 text-slate-400">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
            <img src="{{ url('theme://images/favicon.png') }}" alt="{{ site.title }}" class="w-7 h-7 rounded-lg">
            <span class="text-white font-medium">{{ site.title }}</span>
        </div>
        {% if h.contact.email %}
        <div class="text-sm">
            Vragen? <a href="mailto:{{ h.contact.email }}" class="text-sail-400 hover:text-sail-300">{{ h.contact.email }}</a>
        </div>
        {% endif %}
        <div class="text-xs">{{ h.contact.footer_text ?: '© 2025 SAIL Project' }}</div>
    </div>
</footer>

{% endblock %}
