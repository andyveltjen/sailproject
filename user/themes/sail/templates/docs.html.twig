{% extends 'partials/base.html.twig' %}

{% set tags = page.taxonomy.tag %}
{% if tags %}
    {% set progress = page.collection({'items':{'@taxonomy':{'category': 'docs', 'tag': tags}},'order': {'by': 'default', 'dir': 'asc'}}) %}
{% else %}
    {% set progress = page.collection({'items':{'@taxonomy':{'category': 'docs'}},'order': {'by': 'default', 'dir': 'asc'}}) %}
{% endif %}

{# Haal wiki_active op van de wiki-rootpagina #}
{% set wiki_root = page.find('/wiki') %}
{% set wiki_active = wiki_root.header.wiki_active is defined ? wiki_root.header.wiki_active : true %}
{% set wiki_inactive_message = wiki_root.header.wiki_inactive_message ?: 'De Wiki of Research is momenteel nog niet publiek beschikbaar. We werken aan de eerste inhoud en openen de wiki binnenkort.' %}

{% block body %}
<div class="flex h-screen overflow-hidden bg-white">

    {# ── Sidebar ── #}
    <aside id="wiki-sidebar"
           class="fixed md:static z-40 flex flex-col w-64 h-full bg-white border-r border-slate-100 overflow-y-auto flex-shrink-0">

        {# Logo en terug-link altijd tonen #}
        <div class="px-5 py-4 border-b border-slate-100">
            <a href="{{ base_url_absolute }}" class="flex items-center">
                <img src="{{ url('theme://images/logo.png') }}" alt="{{ site.title }}" class="h-8 w-auto">
            </a>
            <div class="text-sail-500 text-xs font-medium mt-1.5 pl-0.5">Wiki of Research</div>
        </div>
        <div class="px-4 pt-3 pb-1">
            <a href="{{ base_url_absolute }}" class="flex items-center gap-2 text-slate-400 hover:text-sail-600 text-xs transition-colors">
                <i class="fa fa-arrow-left"></i> Terug naar project
            </a>
        </div>

        {# Navigatie enkel tonen als wiki actief is #}
        {% if wiki_active %}
            {% include 'partials/sidebar-nav.html.twig' %}
        {% else %}
            <div class="px-4 pt-4">
                <div class="text-xs text-slate-300 italic px-3 py-2">
                    Wiki is momenteel niet beschikbaar.
                </div>
            </div>
        {% endif %}

    </aside>

    {# ── Mobile overlay ── #}
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" onclick="closeSidebar()"></div>

    {# ── Main content ── #}
    <div class="flex-1 flex flex-col min-w-0 overflow-y-auto">

        {# Top bar (mobile) #}
        <div class="md:hidden flex items-center gap-3 px-4 py-3 border-b border-slate-100 sticky top-0 bg-white z-20">
            <button onclick="openSidebar()" class="text-slate-600 hover:text-slate-900">
                <i class="fa fa-bars text-lg"></i>
            </button>
            <span class="text-sm font-medium text-slate-700 truncate">{{ page.title }}</span>
        </div>

        {# Content #}
        <main class="flex-1 max-w-4xl mx-auto w-full px-8 py-10">
            {% if wiki_active %}
                <article class="prose">
                    <h1 class="!mt-0">{{ page.title }}</h1>
                    {{ page.content|raw }}
                </article>

                {# Prev / Next navigatie #}
                {% if progress %}
                <div class="flex items-center justify-between mt-16 pt-6 border-t border-slate-100">
                    {% if not progress.isFirst(page.path) %}
                        {% set prev = progress.nextSibling(page.path) %}
                        <a href="{{ prev.url }}" class="flex items-center gap-2 text-sm text-slate-500 hover:text-sail-600 transition-colors group">
                            <i class="fa fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                            <div>
                                <div class="text-xs text-slate-400">Vorige</div>
                                <div class="font-medium">{{ prev.title }}</div>
                            </div>
                        </a>
                    {% else %}<span></span>{% endif %}

                    {% if not progress.isLast(page.path) %}
                        {% set next = progress.prevSibling(page.path) %}
                        <a href="{{ next.url }}" class="flex items-center gap-2 text-sm text-slate-500 hover:text-sail-600 transition-colors text-right group">
                            <div>
                                <div class="text-xs text-slate-400">Volgende</div>
                                <div class="font-medium">{{ next.title }}</div>
                            </div>
                            <i class="fa fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                        </a>
                    {% else %}<span></span>{% endif %}
                </div>
                {% endif %}

            {% else %}
                {# Wiki inactief — toon boodschap #}
                <div class="flex flex-col items-center justify-center min-h-96 text-center px-4">
                    <div class="w-16 h-16 rounded-2xl bg-sail-50 flex items-center justify-center mb-6">
                        <i class="fa fa-clock-o text-sail-400 text-2xl"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900 mb-3">Wiki of Research</h2>
                    <p class="text-slate-500 max-w-md leading-relaxed mb-8">{{ wiki_inactive_message }}</p>
                    <a href="{{ base_url_absolute }}" class="inline-flex items-center gap-2 bg-sail-500 hover:bg-sail-600 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
                        <i class="fa fa-arrow-left text-xs"></i> Terug naar het project
                    </a>
                </div>
            {% endif %}
        </main>

        {# Footer #}
        <footer class="border-t border-slate-100 px-8 py-4 text-xs text-slate-400 flex items-center justify-between">
            <span>{{ site.title }} — Wiki of Research</span>
            <a href="{{ base_url_absolute }}" class="hover:text-sail-500 transition-colors">← Terug naar project</a>
        </footer>
    </div>
</div>

<script>
function openSidebar() {
    document.getElementById('wiki-sidebar').classList.add('open');
    document.getElementById('sidebar-overlay').classList.remove('hidden');
}
function closeSidebar() {
    document.getElementById('wiki-sidebar').classList.remove('open');
    document.getElementById('sidebar-overlay').classList.add('hidden');
}
</script>
{% endblock %}
