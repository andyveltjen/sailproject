{% extends 'partials/base.html.twig' %}

{% set tags = page.taxonomy.tag %}
{% if tags %}
    {% set progress = page.collection({'items':{'@taxonomy':{'category': 'docs', 'tag': tags}},'order': {'by': 'default', 'dir': 'asc'}}) %}
{% else %}
    {% set progress = page.collection({'items':{'@taxonomy':{'category': 'docs'}},'order': {'by': 'default', 'dir': 'asc'}}) %}
{% endif %}

{# Haal wiki_active op van de site-configuratie #}
{% set wiki_active = config.site.wiki.active is defined ? config.site.wiki.active : true %}

{% block body %}
<div class="flex h-screen overflow-hidden bg-white">

    {# ── Sidebar ── #}
    <aside id="wiki-sidebar"
           class="fixed md:static z-40 flex flex-col w-64 h-full bg-white border-r border-slate-100 overflow-y-auto flex-shrink-0">

        {# Logo en terug-link altijd tonen #}
        <div class="px-5 py-4 border-b border-slate-100">
            <a href="{{ base_url_absolute }}" class="flex items-center">
                <img src="{{ url('theme://images/logo.png') }}" alt="{{ site.title }}" class="h-8 w-auto">
            </a>
            <div class="text-sail-500 text-xs font-medium mt-1.5 pl-0.5">{{ 'SAIL.WIKI_SUBTITLE'|t }}</div>
        </div>
        <div class="px-4 pt-3 pb-1">
            <a href="{{ base_url_absolute }}" class="flex items-center gap-2 text-slate-400 hover:text-sail-600 text-xs transition-colors">
                <i class="fa fa-arrow-left"></i> {{ 'SAIL.BACK_TO_PROJECT'|t }}
            </a>
        </div>

        {# Navigatie enkel tonen als wiki actief is #}
        {% if wiki_active %}
            {% include 'partials/sidebar-nav.html.twig' %}
        {% else %}
            <div class="px-4 pt-4">
                <div class="text-xs text-slate-300 italic px-3 py-2">
                    {{ 'SAIL.WIKI_INACTIVE_SHORT'|t }}
                </div>
            </div>
        {% endif %}

    </aside>

    {# ── Mobile overlay ── #}
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 hidden md:hidden" onclick="closeSidebar()"></div>

    {# ── Main content ── #}
    <div class="flex-1 flex flex-col min-w-0 overflow-y-auto">

        {# Top bar (mobile) #}
        <div class="md:hidden flex items-center gap-3 px-4 py-3 border-b border-slate-100 sticky top-0 bg-white z-20">
            <button onclick="openSidebar()" class="text-slate-600 hover:text-slate-900">
                <i class="fa fa-bars text-lg"></i>
            </button>
            <span class="text-sm font-medium text-slate-700 truncate">{{ page.title }}</span>
        </div>

        {# Content #}
        <main class="flex-1 max-w-4xl mx-auto w-full px-8 py-10">
            {% if wiki_active %}
                <article class="prose">
                    <h1 class="!mt-0">{{ page.title }}</h1>
                    {{ page.content|raw }}
                </article>

                {# Prev / Next navigatie #}
                {% if progress %}
                <div class="flex items-center justify-between mt-16 pt-6 border-t border-slate-100">
                    {% if not progress.isFirst(page.path) %}
                        {% set prev = progress.nextSibling(page.path) %}
                        <a href="{{ prev.url }}" class="flex items-center gap-2 text-sm text-slate-500 hover:text-sail-600 transition-colors group">
                            <i class="fa fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                            <div>
                                <div class="text-xs text-slate-400">{{ 'SAIL.PREV'|t }}</div>
                                <div class="font-medium">{{ prev.title }}</div>
                            </div>
                        </a>
                    {% else %}<span></span>{% endif %}

                    {% if not progress.isLast(page.path) %}
                        {% set next = progress.prevSibling(page.path) %}
                        <a href="{{ next.url }}" class="flex items-center gap-2 text-sm text-slate-500 hover:text-sail-600 transition-colors text-right group">
                            <div>
                                <div class="text-xs text-slate-400">{{ 'SAIL.NEXT'|t }}</div>
                                <div class="font-medium">{{ next.title }}</div>
                            </div>
                            <i class="fa fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                        </a>
                    {% else %}<span></span>{% endif %}
                </div>
                {% endif %}

            {% else %}
                {# Wiki inactief — toon boodschap #}
                <div class="flex flex-col items-center justify-center min-h-96 text-center px-4">
                    <div class="w-16 h-16 rounded-2xl bg-sail-50 flex items-center justify-center mb-6">
                        <i class="fa fa-clock-o text-sail-400 text-2xl"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900 mb-3">{{ 'SAIL.WIKI_INACTIVE_TITLE'|t }}</h2>
                    <p class="text-slate-500 max-w-md leading-relaxed mb-8">{{ 'SAIL.WIKI_INACTIVE_MSG'|t }}</p>
                    <a href="{{ base_url_absolute }}" class="inline-flex items-center gap-2 bg-sail-500 hover:bg-sail-600 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
                        <i class="fa fa-arrow-left text-xs"></i> {{ 'SAIL.BACK_TO_PROJECT_BTN'|t }}
                    </a>
                </div>
            {% endif %}
        </main>

        {# Footer #}
        <footer class="border-t border-slate-100 px-8 py-4 text-xs text-slate-400 flex items-center justify-between">
            <span>{{ site.title }} — {{ 'SAIL.WIKI_SUBTITLE'|t }}</span>
            <a href="{{ base_url_absolute }}" class="hover:text-sail-500 transition-colors">← {{ 'SAIL.BACK_TO_PROJECT'|t }}</a>
        </footer>
    </div>
</div>

<script>
// ── DOM-ready helper (werkt ook als DOMContentLoaded al gevuurd is) ───────────
function onDomReady(fn) {
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fn);
    } else {
        fn();
    }
}

// ── Highlight tekst op basis van ?hl= URL-parameter ──────────────────────────
(function () {
    const phrase = new URLSearchParams(window.location.search).get('hl');
    if (!phrase) return;
    onDomReady(() => sailHighlightText(phrase));
})();

function sailHighlightText(phrase) {
    const article = document.querySelector('article.prose');
    if (!article) return;

    // 1. Probeer progressief kortere woordreeksen (volledige zin → 3 woorden)
    const words = phrase.trim().split(/\s+/);
    for (let len = words.length; len >= 3; len--) {
        const search = words.slice(0, len).join(' ').toLowerCase();
        if (sailMarkText(article, search)) return;
    }

    // 2. Fallback: zoek een heading die een van de woorden bevat
    const significant = words.filter(w => w.length > 4);
    for (const heading of article.querySelectorAll('h1,h2,h3,h4')) {
        const ht = heading.textContent.toLowerCase();
        if (significant.some(w => ht.includes(w))) {
            heading.classList.add('sail-hl');
            heading.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => heading.classList.remove('sail-hl'), 4000);
            return;
        }
    }

    // 3. Laatste fallback: highlight de eerste paragraaf en scroll naar boven
    const first = article.querySelector('p');
    if (first) {
        first.classList.add('sail-hl');
        first.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => first.classList.remove('sail-hl'), 4000);
    }
}

function sailMarkText(article, search) {
    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT);
    while (walker.nextNode()) {
        const node  = walker.currentNode;
        const lower = node.textContent.toLowerCase();
        const idx   = lower.indexOf(search);
        if (idx === -1) continue;

        try {
            const range = document.createRange();
            range.setStart(node, idx);
            range.setEnd(node, Math.min(idx + search.length, node.textContent.length));
            const mark = document.createElement('mark');
            mark.className = 'sail-hl';
            range.surroundContents(mark);
            mark.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => mark.replaceWith(...mark.childNodes), 4000);
        } catch (_) {
            const parent = node.parentElement;
            parent.classList.add('sail-hl');
            parent.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => parent.classList.remove('sail-hl'), 4000);
        }
        return true;
    }
    return false;
}

function openSidebar() {
    document.getElementById('wiki-sidebar').classList.add('open');
    document.getElementById('sidebar-overlay').classList.remove('hidden');
}
function closeSidebar() {
    document.getElementById('wiki-sidebar').classList.remove('open');
    document.getElementById('sidebar-overlay').classList.add('hidden');
}
function sailNavToggle(btn) {
    const li   = btn.closest('li');
    const ul   = li.querySelector('[data-nav-children]');
    const icon = btn.querySelector('i');
    if (ul) {
        ul.classList.toggle('hidden');
        icon.classList.toggle('rotate-90');
    }
}

// ── Zoekresultaten renderen ───────────────────────────────────────────────────
function sailRenderResults(data, rootUrl, lang) {
    const results = document.getElementById('sail-search-results');
    const isNl    = lang !== 'en';
    if (!results) return;

    if (!data.answer) {
        results.innerHTML = isNl ? 'Geen antwoord gevonden.' : 'No answer found.';
        results.classList.remove('hidden');
        return;
    }

    const langPrefix = lang === 'en' ? '/en' : '';

    let refsHtml = '';
    if (data.refs && data.refs.length > 0) {
        const label = isNl ? 'Lees verder in:' : 'Read more in:';
        const links = data.refs.map(r => {
            let href = rootUrl + langPrefix + r.path;
            if (r.phrase) href += '?hl=' + encodeURIComponent(r.phrase);
            return `<a href="${href}"
                       class="inline-flex items-center gap-1 text-[10px] bg-white border
                              border-sail-200 text-sail-600 rounded-md px-2 py-1
                              hover:bg-sail-50 transition-colors">
                        <i class="fa fa-file-text-o text-[8px]"></i> ${r.title}
                    </a>`;
        }).join('');
        refsHtml = `<div class="mt-2.5 pt-2 border-t border-sail-100">
            <span class="text-[10px] text-slate-400 uppercase tracking-wide">${label}</span>
            <div class="flex flex-wrap gap-1 mt-1">${links}</div>
        </div>`;
    }

    results.innerHTML = `
        <div class="flex items-start justify-between gap-1 mb-1.5">
            <span class="text-[10px] text-slate-400 uppercase tracking-wide flex items-center gap-1">
                <i class="fa fa-comment-o text-sail-400"></i>
                ${isNl ? 'Antwoord' : 'Answer'}
            </span>
            <button onclick="sailClearSearch()"
                    title="${isNl ? 'Verwijder zoekresultaat' : 'Clear search result'}"
                    class="text-slate-300 hover:text-slate-500 transition-colors leading-none">
                <i class="fa fa-times text-xs"></i>
            </button>
        </div>
        <p class="text-xs text-slate-600 leading-relaxed">${data.answer.replace(/\n/g, '<br>')}</p>
        ${refsHtml}`;

    results.classList.remove('hidden');
}

// ── Zoekresultaat wissen ──────────────────────────────────────────────────────
function sailClearSearch() {
    sessionStorage.removeItem('sail_search');
    const results = document.getElementById('sail-search-results');
    const input   = document.getElementById('sail-search-input');
    if (results) results.classList.add('hidden');
    if (input)   input.value = '';
}

// ── Zoeken uitvoeren ──────────────────────────────────────────────────────────
async function sailSearch() {
    const box   = document.querySelector('[data-search-url]');
    const input = document.getElementById('sail-search-input');
    const res   = document.getElementById('sail-search-results');
    if (!box || !input || !res) return;

    const question = input.value.trim();
    if (!question) { input.focus(); return; }

    const url     = box.dataset.searchUrl;
    const lang    = box.dataset.lang || 'nl';
    const rootUrl = url.replace('/wiki-search', '');
    const isNl    = lang !== 'en';

    res.classList.remove('hidden');
    res.innerHTML = `<span class="text-slate-400 flex items-center gap-1.5 text-xs">
        <i class="fa fa-spinner fa-spin text-sail-400"></i>
        ${isNl ? 'Zoeken…' : 'Searching…'}
    </span>`;

    try {
        const resp = await fetch(url, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ question, lang }),
        });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();

        // Opslaan in sessionStorage zodat het na navigatie behouden blijft
        sessionStorage.setItem('sail_search', JSON.stringify({ question, answer: data.answer, refs: data.refs || [], lang, rootUrl }));

        sailRenderResults(data, rootUrl, lang);
    } catch (e) {
        res.innerHTML = `<span class="text-red-400 text-xs">
            ${isNl ? 'Er ging iets mis. Probeer opnieuw.' : 'Something went wrong. Please try again.'}
        </span>`;
    }
}

// ── Zoekresultaat herstellen na paginanavigatie ───────────────────────────────
(function sailRestoreSearch() {
    const saved = sessionStorage.getItem('sail_search');
    if (!saved) return;
    try {
        const state = JSON.parse(saved);
        onDomReady(() => {
            const input = document.getElementById('sail-search-input');
            if (input) input.value = state.question;
            sailRenderResults(
                { answer: state.answer, refs: state.refs },
                state.rootUrl,
                state.lang
            );
        });
    } catch (_) {
        sessionStorage.removeItem('sail_search');
    }
})();
</script>
{% endblock %}
