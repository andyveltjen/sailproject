{# ──────────────────────────────────────────────────────────────────────
   Sidebar navigatie — recursief met level-bewuste iconen en uitklappen
   level 1 = hoofdsecties  |  level 2 = subsecties
────────────────────────────────────────────────────────────────────── #}

{% macro navloop(page, level) %}
    {% import _self as self %}
    {% set level = level is defined ? level : 1 %}
    {% for p in page.children.visible %}
        {% set is_active    = p.active ? true : false %}
        {% set is_parent    = p.activeChild ? true : false %}
        {% set has_children = p.children.count > 0 %}
        {% set is_open      = is_active or is_parent %}

        <li>
            <div class="flex items-center gap-0.5">

                {# ── Indicator / toggle ────────────────────────────────── #}
                {% if level == 1 and has_children %}
                    {# Hoofdsectie mét kinderen → klikbare chevron #}
                    <button onclick="sailNavToggle(this)"
                            class="w-5 h-6 flex items-center justify-center flex-shrink-0
                                   text-slate-300 hover:text-slate-500 transition-colors"
                            aria-label="Uitklappen">
                        <i class="fa fa-chevron-right text-[9px] transition-transform duration-200
                                  {% if is_open %}rotate-90{% endif %}"></i>
                    </button>

                {% elseif level == 1 %}
                    {# Hoofdsectie zonder kinderen → klein vierkantje #}
                    <span class="w-5 flex-shrink-0 flex items-center justify-center">
                        <i class="fa text-[8px] flex-shrink-0
                                  {% if is_active %}fa-square text-sail-500{% else %}fa-square-o text-slate-300{% endif %}"></i>
                    </span>

                {% else %}
                    {# Subsectie → streepje of gevulde stip #}
                    <span class="w-4 flex-shrink-0 flex items-center justify-center">
                        <i class="fa text-[7px] flex-shrink-0
                                  {% if is_active %}fa-circle text-sail-400{% else %}fa-minus text-slate-200{% endif %}"></i>
                    </span>
                {% endif %}

                {# ── Link ─────────────────────────────────────────────── #}
                <a href="{{ p.url }}"
                   class="flex-1 py-1.5 px-2 rounded-md text-sm transition-colors truncate
                          {% if level == 1 %}
                              {% if is_active %}
                                  bg-sail-50 text-sail-700 font-semibold
                              {% elseif is_parent %}
                                  text-slate-700 font-medium
                              {% else %}
                                  text-slate-500 hover:text-slate-700 hover:bg-slate-50
                              {% endif %}
                          {% else %}
                              {% if is_active %}
                                  text-sail-600 font-medium
                              {% else %}
                                  text-slate-400 hover:text-slate-600 hover:bg-slate-50
                              {% endif %}
                          {% endif %}">
                    {{ p.menu }}
                </a>

            </div>

            {# ── Kinderen — subtiele verticale lijn als verbinding ──── #}
            {% if has_children %}
            <ul class="mt-0.5 space-y-0.5 ml-5 pl-2.5 border-l border-slate-100
                       {% if not is_open %}hidden{% endif %}"
                data-nav-children>
                {{ self.navloop(p, level + 1) }}
            </ul>
            {% endif %}

        </li>
    {% endfor %}
{% endmacro %}

{% import _self as macro %}

<nav class="px-3 pb-6 overflow-y-auto flex-1">
    <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider px-3 mb-2 mt-3">{{ 'SAIL.WIKI_CONTENT'|t }}</div>
    <ul class="space-y-0.5">
        {% set wiki_page = page.find('/wiki') %}
        {% if wiki_page %}
            {{ macro.navloop(wiki_page) }}
        {% else %}
            {{ macro.navloop(pages) }}
        {% endif %}
    </ul>
</nav>
