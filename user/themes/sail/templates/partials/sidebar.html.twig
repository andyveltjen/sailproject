{% macro navloop(page) %}
    {% import _self as self %}
    {% for p in page.children.visible %}
        {% set is_active = p.active ? true : false %}
        {% set is_parent = p.activeChild ? true : false %}
        <li>
            <a href="{{ p.url }}"
               class="sidebar-link {% if is_active %}active{% elseif is_parent %}parent{% endif %}">
                {% if is_active %}
                    <i class="fa fa-circle text-xs flex-shrink-0"></i>
                {% else %}
                    <i class="fa fa-circle-o text-xs flex-shrink-0 opacity-40"></i>
                {% endif %}
                <span>{{ p.menu }}</span>
            </a>
            {% if p.children.count > 0 and (is_active or is_parent) %}
            <ul class="ml-4 mt-1 space-y-0.5">
                {{ self.navloop(p) }}
            </ul>
            {% endif %}
        </li>
    {% endfor %}
{% endmacro %}

{% import _self as macro %}

{# Logo #}
<div class="p-5 border-b border-slate-800">
    <a href="{{ base_url_absolute }}" class="flex items-center gap-2 group">
        <span class="w-8 h-8 rounded-lg bg-sail-500 flex items-center justify-center flex-shrink-0">
            <span class="text-white font-bold text-sm">S</span>
        </span>
        <div>
            <div class="text-white font-semibold text-sm leading-tight">{{ site.title }}</div>
            <div class="text-slate-500 text-xs">Wiki of Research</div>
        </div>
    </a>
</div>

{# Terug naar project #}
<div class="px-4 pt-4">
    <a href="{{ base_url_absolute }}" class="flex items-center gap-2 text-slate-500 hover:text-slate-300 text-xs mb-4 transition-colors">
        <i class="fa fa-arrow-left"></i> Terug naar project
    </a>
</div>

{# Navigatie #}
<nav class="px-3 pb-6 overflow-y-auto flex-1">
    <div class="text-xs font-semibold text-slate-600 uppercase tracking-wider px-3 mb-2">Inhoud</div>
    <ul class="space-y-0.5">
        {% set wiki_page = page.find('/wiki') %}
        {% if wiki_page %}
            {{ macro.navloop(wiki_page) }}
        {% else %}
            {{ macro.navloop(pages) }}
        {% endif %}
    </ul>
</nav>
