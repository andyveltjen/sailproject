{% macro navloop(page) %}
    {% import _self as self %}
    {% for p in page.children.visible %}
        {% set is_active = p.active ? true : false %}
        {% set is_parent = p.activeChild ? true : false %}
        <li>
            <a href="{{ p.url }}"
               class="sidebar-link {% if is_active %}active{% elseif is_parent %}parent{% endif %}">
                {% if is_active %}
                    <i class="fa fa-circle text-xs flex-shrink-0"></i>
                {% else %}
                    <i class="fa fa-circle-o text-xs flex-shrink-0 opacity-40"></i>
                {% endif %}
                <span>{{ p.menu }}</span>
            </a>
            {% if p.children.count > 0 and (is_active or is_parent) %}
            <ul class="ml-4 mt-1 space-y-0.5">
                {{ self.navloop(p) }}
            </ul>
            {% endif %}
        </li>
    {% endfor %}
{% endmacro %}

{% import _self as macro %}

{# Logo #}
<div class="px-5 py-4 border-b border-slate-100">
    <a href="{{ base_url_absolute }}" class="flex items-center">
        <img src="{{ url('theme://images/logo.png') }}" alt="{{ site.title }}" class="h-8 w-auto">
    </a>
    <div class="text-sail-500 text-xs font-medium mt-1.5 pl-0.5">Wiki of Research</div>
</div>

{# Terug naar project + taalwisselaar #}
<div class="px-4 pt-3 pb-1 flex items-center justify-between">
    <a href="{{ base_url_absolute }}" class="flex items-center gap-2 text-slate-400 hover:text-sail-600 text-xs transition-colors">
        <i class="fa fa-arrow-left"></i> {{ 'SAIL.BACK_TO_PROJECT'|t }}
    </a>
    {% set current_lang = grav.language.getActive %}
    {% set root_url = grav.uri.rootUrl(true) %}
    {% set raw = page.rawRoute %}
    <div class="flex items-center gap-1.5 text-xs text-slate-400">
        <a href="{{ root_url }}{{ raw }}"
           class="transition-colors {% if current_lang == 'nl' or not current_lang %}text-slate-700 font-semibold{% else %}hover:text-slate-600{% endif %}">NL</a>
        <span class="text-slate-300">·</span>
        <a href="{{ root_url }}/en{{ raw }}"
           class="transition-colors {% if current_lang == 'en' %}text-slate-700 font-semibold{% else %}hover:text-slate-600{% endif %}">EN</a>
    </div>
</div>

{# Navigatie #}
<nav class="px-3 pb-6 overflow-y-auto flex-1">
    <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider px-3 mb-2 mt-3">{{ 'SAIL.WIKI_CONTENT'|t }}</div>
    <ul class="space-y-0.5">
        {% set wiki_page = page.find('/wiki') %}
        {% if wiki_page %}
            {{ macro.navloop(wiki_page) }}
        {% else %}
            {{ macro.navloop(pages) }}
        {% endif %}
    </ul>
</nav>
